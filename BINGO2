<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BINGOゲーム</title>
<style>
  body {
    font-family: sans-serif;
    text-align: center;
    background: linear-gradient(135deg, #ffdde1, #ee9ca7);
    margin: 0;
    padding: 20px;
  }

  h1 { margin-bottom: 10px; }

  #board {
    display: grid;
    grid-template-columns: repeat(5, 70px);
    gap: 10px;
    justify-content: center;
    margin: 20px auto;
  }

  .cell {
    width: 70px;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: white;
    border-radius: 15px;
    font-weight: bold;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    transition: 0.2s;
  }

  .marked {
    background: #ff4d88;
    color: white;
    transform: scale(1.1);
  }

  button {
    padding: 10px 20px;
    border: none;
    border-radius: 20px;
    background: #ff4d88;
    color: white;
    font-size: 16px;
    cursor: pointer;
    margin: 5px;
  }

  #drawn, #history {
    margin-top: 10px;
    font-size: 18px;
  }

  #history {
    max-width: 350px;
    margin: 10px auto;
    background: white;
    padding: 10px;
    border-radius: 15px;
  }

  #message {
    margin-top: 20px;
    font-size: 24px;
    font-weight: bold;
    color: #fff;
  }
</style>
</head>
<body>

<h1>🎉 BINGOゲーム 🎉</h1>
<button onclick="generateBoard()">リセット</button>
<button onclick="drawNumber()">数字を引く</button>
<button onclick="toggleBGM()">BGM ON/OFF</button>

<div id="drawn">引いた数字：なし</div>
<div id="history">履歴：なし</div>
<div id="board"></div>
<div id="message"></div>

<audio id="bgm" loop>
  <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
</audio>

<script>
let numbers = [];
let drawnNumbers = [];
let bgmPlaying = false;

function generateBoard() {
  const boardDiv = document.getElementById('board');
  document.getElementById('message').textContent = '';
  document.getElementById('drawn').textContent = '引いた数字：なし';
  document.getElementById('history').textContent = '履歴：なし';

  boardDiv.innerHTML = '';

  numbers = Array.from({length: 25}, (_, i) => i + 1);
  numbers.sort(() => Math.random() - 0.5);
  drawnNumbers = [];

  numbers.forEach(num => {
    const cell = document.createElement('div');
    cell.classList.add('cell');
    cell.textContent = num;
    boardDiv.appendChild(cell);
  });
}

function drawNumber() {
  if (drawnNumbers.length === 25) return;

  let remaining = numbers.filter(n => !drawnNumbers.includes(n));
  let num = remaining[Math.floor(Math.random() * remaining.length)];

  drawnNumbers.push(num);

  document.getElementById('drawn').textContent = '引いた数字：' + num;
  document.getElementById('history').textContent = '履歴：' + drawnNumbers.join(', ');

  document.querySelectorAll('.cell').forEach(cell => {
    if (Number(cell.textContent) === num) {
      cell.classList.add('marked');
    }
  });

  checkBingo();
}

function checkBingo() {
  const cells = document.querySelectorAll('.cell');
  const grid = [];

  for (let i = 0; i < 5; i++) {
    grid[i] = [];
    for (let j = 0; j < 5; j++) {
      grid[i][j] = cells[i * 5 + j].classList.contains('marked');
    }
  }

  let bingo = false;

  for (let i = 0; i < 5; i++) {
    if (grid[i].every(v => v)) bingo = true;
  }

  for (let j = 0; j < 5; j++) {
    if (grid.every(row => row[j])) bingo = true;
  }

  if ([0,1,2,3,4].every(i => grid[i][i])) bingo = true;
  if ([0,1,2,3,4].every(i => grid[i][4-i])) bingo = true;

  if (bingo) {
    document.getElementById('message').textContent = '✨ BINGO！✨';
  }
}

function toggleBGM() {
  const bgm = document.getElementById('bgm');
  if (!bgmPlaying) {
    bgm.play();
    bgmPlaying = true;
  } else {
    bgm.pause();
    bgmPlaying = false;
  }
}

generateBoard();
</script>

</body>
</html>

